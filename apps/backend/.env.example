PORT=4000
NODE_ENV=development

# PostgreSQL — matches docker-compose.yml defaults for local dev
DATABASE_URL="postgresql://vitamina:vitamina@localhost:5432/vitamina_dev"

# JWT — replace with a long random secret in production
# Generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# Bcrypt
BCRYPT_ROUNDS=12

# CORS — comma-separated list of allowed frontend origins
# Development: http://localhost:3000
# Production:  https://vitamina.vercel.app
FRONTEND_URL="http://localhost:3000"

# Uploads directory (optional)
# Leave unset locally — defaults to <cwd>/uploads
# On Render with a persistent disk: /opt/render/project/uploads
# UPLOADS_DIR="/opt/render/project/uploads"